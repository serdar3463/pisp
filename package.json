{
  "name": "pisp-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "test": "node node_modules/jest/bin/jest.js --passWithNoTests",
    "test:invariants": "node scripts/pisp-invariants.test.js",
    "check": "npm run typecheck && npm run lint",
    "release:check": "npm run check && npm run test && npm run test:invariants",
    "beta:check": "npm run release:check && node scripts/launch-readiness.js --profile=beta",
    "launch:check": "npm run release:check && node scripts/launch-readiness.js --profile=public",
    "configure:production": "node scripts/configure-production.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-contacts": "~15.0.11",
    "expo-crypto": "~15.0.0",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-local-authentication": "~17.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-sharing": "~14.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-svg": "15.12.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "babel-preset-expo": "~54.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
