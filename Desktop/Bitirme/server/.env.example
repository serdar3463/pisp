# Server
PORT=3001
NODE_ENV=development

# JWT — change this to a long random string in production!
JWT_SECRET=pisp-change-me-in-production-use-openssl-rand-hex-64

# Database
DB_PATH=./pisp.db

# Iyzico — get from iyzico.com
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_ENV=sandbox   # or: production

# Offer QR signature secret
OFFER_SECRET=pisp-offer-hmac-secret-change-in-production

# Admin panel access
ADMIN_SECRET=change-this-admin-secret

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://pisp.app,http://localhost:3000
