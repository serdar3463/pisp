# PISP Mobile - Environment Variables
# Bu dosyayı .env olarak kopyalayıp gerçek değerleri gir.
# .env asla git'e eklenmez.

# Public URLs (App Store ve yasal belgeler için)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://pisp.app/privacy
EXPO_PUBLIC_SUPPORT_URL=https://pisp.app/support
EXPO_PUBLIC_DATA_DELETION_URL=https://pisp.app/delete-data

# Sentry error tracking (üretimde zorunlu)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# App versiyonu
EXPO_PUBLIC_APP_VERSION=1.0.0

